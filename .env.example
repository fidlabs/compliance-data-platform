NODE_ENV="development"
TZ="UTC"

DATABASE_URL="postgresql://localhost/postgres?schema=public&connection_limit=50"
DMOB_DATABASE_URL="postgresql://localhost/postgres?schema=dmob"

GOOGLEAPIS_KEY="" # used for /proxy/googleapis/* endpoints
IP_INFO_TOKEN=""  # used for https://ipinfo.io endpoints

GITHUB_APP_ID=""      # used for GitHub triggers handling and allocator registry service
GITHUB_PRIVATE_KEY="" # used for GitHub triggers handling and allocator registry service, use \n for new lines

GLIF_API_BASE_URL="https://api.node.glif.io/rpc"
FILSCAN_API_BASE_URL="https://api-v2.filscan.io/api"

CLIENT_REPORT_MAX_PROVIDER_DEAL_PERCENTAGE=25
CLIENT_REPORT_MAX_DUPLICATION_PERCENTAGE=20
CLIENT_REPORT_MAX_PERCENTAGE_FOR_LOW_REPLICA=25                   # max % of data that have low replica number
CLIENT_REPORT_MAX_PERCENTAGE_FOR_REQUIRED_COPIES=34               # max % of data that doesn't have required copies
CLIENT_REPORT_MAX_PERCENTAGE_NOT_DECLARED_PROVIDERS=30            # max % of storage providers not declared in client application file
CLIENT_REPORT_MAX_PERCENTAGE_FOR_HIGH_REPLICA=25                  # max % of data that have high replica number
CLIENT_REPORT_TOTAL_UNIQ_DATA_SET_SIZE_ALLOW_EXCEEDS_PERCENTAGE=5 # max % of total unique data set size that can exceed the requested size in client application

PROMETHEUS_AUTH_TOKEN=""
PROMETHEUS_METRICS_ENV="staging"

ALLOCATOR_REGISTRY_REPO_OWNER="Neti-Test"
ALLOCATOR_REGISTRY_REPO_NAME="filplus-allocator-governance"

URL_FINDER_API_URL="https://api.sp-tool.allocator.tech" # Base URL for the URL Finder API service

# PO REP
PO_REP_CHAIN_ID=314 # Chain ID on which Po-Rep contracts live
PO_REP_ARCHIVE_RPC_URL="https://filecoin.chain.love/fvm-archive/rpc/v1" # URL of archive node RPC
PO_REP_ARCHIVE_RPC_AUTH_TOKEN= # (Optional) Bearer token that will be included in headers of requests made to archive node
PO_REP_RECENT_RPC_URL= # (Optional) URL of recent node RPC, if not provided default URL configured in viem will be used
PO_REP_RECENT_RPC_AUTH_TOKEN= # (Optional) Bearer token that will be included in headers of requests made to recent node
SP_REGISTRY_CONTRACT_ADDRESS="" # Address of SPRegistry contract
PO_REP_MARKET_CONTRACT_ADDRESS="" # Address of PoRepMarket contract